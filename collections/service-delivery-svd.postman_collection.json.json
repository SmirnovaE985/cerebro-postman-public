                      "\r",
                      "// Проверяем, что в ответе есть корневое поле data\r",
                      "pm.test(\"Response contains data\", function () {\r",
                      "    pm.expect(json).to.have.property(\"data\");\r",
                      "    pm.expect(json.data).to.be.an(\"object\");\r",
                      "});\r",
                      "\r",
                      "// Список групп транспорта, которые ожидаем получить в ответе\r",
                      "const groups = [\"courierGroup\", \"loadersGroup\", \"manipulatorGroup\", \"otherGroup\"];\r",
                      "\r",
                      "// Проходим по каждой группе и выполняем одинаковые проверки\r",
                      "groups.forEach((groupName) => {\r",
                      "    \r",
                      "    // Проверяем, что текущая группа присутствует в ответе\r",
                      "    pm.test(`${groupName} exists`, function () {\r",
                      "        pm.expect(json.data).to.have.property(groupName);\r",
                      "    });\r",
                      "\r",
                      "    // Проверяем, что у группы есть поле transports и оно является массивом\r",
                      "    pm.test(`${groupName} has transports array`, function () {\r",
                      "        pm.expect(json.data[groupName]).to.have.property(\"transports\");\r",
                      "        pm.expect(json.data[groupName].transports).to.be.an(\"array\");\r",
                      "    });\r",
                      "\r",
                      "    // Проверяем бизнес-логику:\r",
                      "    // если transports пустой, значит транспорт недоступен,\r",
                      "    // и тогда обязательно должна прийти причина в поле reason\r",
                      "    pm.test(`${groupName}: if transport is unavailable, reason is returned`, function () {\r",
                      "        const group = json.data[groupName];\r",
                      "\r",
                      "        if (group.transports.length === 0) {\r",
                      "            pm.expect(group).to.have.property(\"reason\");\r",
                      "            pm.expect(group.reason).to.not.be.oneOf([null, \"\"]);\r",
                      "            pm.expect(group.reason).to.be.a(\"string\");\r",
                      "        }\r",
                      "    });\r",
                      "});"
